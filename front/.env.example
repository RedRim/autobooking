# Порт на хосте (внутри контейнера всегда 80)
FRONT_PORT=80

# Базовый URL API. Если не задать — в браузере возьмётся тот же хост, порт :8000.
# Для Docker build задайте явно, если нужен другой URL: VITE_API_URL=http://91.202.0.84:8000
# Или общий nginx: VITE_API_URL=/api
# VITE_API_URL=http://localhost:8000
